<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Service de Réanimation - CHU Mustapha</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
    }

    header, footer {
      background-color: #003366;
      color: white;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 20px;
      background-color: #003366;
      border-bottom: 1px solid #002244;
    }

    .auth-buttons {
      display: flex;
      gap: 10px;
    }

    .btn-auth {
      background-color: white;
      color: #003366;
      border: none;
      border-radius: 4px;
      padding: 8px 14px;
      font-weight: bold;
      font-size: 14px;
      cursor: pointer;
      transition: transform 0.2s ease, background-color 0.3s ease;
    }

    .btn-auth:hover {
      transform: scale(1.05);
      background-color: #e6e6e6;
    }

    .header-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 40px;
    }

    .header-content img {
      max-height: 150px;
      height: auto;
      width: auto;
    }

    .titre-et-tagline {
      text-align: center;
      flex: 1;
    }

    .titre-et-tagline h1 {
      font-size: 26px;
      margin: 10px 0 5px;
    }

    nav {
      text-align: center;
      background-color: #002244;
      padding: 10px 0;
    }

    nav a {
      margin: 0 12px;
      text-decoration: none;
      color: white;
      font-weight: bold;
      transition: color 0.3s ease;
    }

    nav a:hover {
      color: #cce0ff;
    }

    main {
      padding: 20px;
      text-align: center;
    }

    footer {
      text-align: center;
      padding: 15px 0;
      margin-top: 30px;
      font-size: 14px;
    }

    .carousel-container {
      width: 90%;
      max-width: 1000px;
      height: 450px;
      margin: 30px auto;
      overflow: hidden;
      position: relative;
      border-radius: 12px;
      box-shadow: 0 0 10px rgba(0,0,0,0.2);
      background-color: #000;
    }

    .carousel-slides {
      display: flex;
      transition: transform 1s ease;
      height: 100%;
    }

    .carousel-slides img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      background-color: black;
      flex-shrink: 0;
    }

    .overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background-color: rgba(0, 0, 0, 0.5);
      color: white;
      padding: 20px 30px;
      border-radius: 10px;
      text-align: center;
    }

    .actualites-container {
      margin-top: 40px;
      padding: 20px;
      border: 2px solid #007BFF;
      border-radius: 10px;
      animation: fadeIn 2s ease-in-out;
    }

    .actualites-title {
      font-size: 32px;
      font-weight: bold;
      color: #007BFF;
      margin-bottom: 10px;
      animation: bounce 2s infinite;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    @keyframes fadeIn {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .poster-wrapper {
      position: fixed;
      top: 30%;
      right: -400px;
      z-index: 10000;
      transition: right 0.4s ease, opacity 0.4s ease;
      opacity: 0.6;
      border-radius: 8px 0 0 8px;
    }

    .poster-wrapper img {
      height: 300px;
      cursor: pointer;
    }

    .poster-wrapper:hover {
      right: 0;
      opacity: 1;
    }

    /* === THÈME CREVETTE/SAUMON POUR KINESITHERAPEUTE === */
    body.orange-theme {
      background-color: #fff2ed;
      color: #4d2e1a;
    }

    body.orange-theme header,
    body.orange-theme .top-bar,
    body.orange-theme nav {
      background-color: #ff6347;
    }

    body.orange-theme .top-bar {
      border-bottom: 1px solid #cc402c;
    }

    body.orange-theme .auth-buttons .btn-auth {
      background-color: #ffe5dc;
      color: #ff6347;
    }

    body.orange-theme .btn-auth:hover {
      background-color: #ffd8cc;
      color: #b8432b;
    }

    body.orange-theme nav a {
      color: white;
    }

    body.orange-theme nav a:hover {
      color: #ffe5dc;
    }

    body.orange-theme .header-content {
      background-color: #ff7f50;
      color: white;
    }

    body.orange-theme .titre-et-tagline h1 {
      color: white;
    }

    body.orange-theme .carousel-container {
      background-color: #fff2ed;
      box-shadow: 0 0 12px rgba(255, 99, 71, 0.3);
    }

    body.orange-theme .overlay {
      background-color: rgba(255, 99, 71, 0.7);
    }

    body.orange-theme .actualites-container {
      border: 2px solid #ff7f50;
      background-color: #fff0eb;
    }

    body.orange-theme .actualites-title {
      color: #ff6347;
    }

    body.orange-theme footer {
      background-color: #ff6347;
      color: white;
    }

    body.orange-theme .header-content img {
      background-color: #ff7f50;
      padding: 8px;
      border-radius: 8px;
    }
    /* === THÈME BLEU GLACIER POUR INFIRMIER === */
    body.iceblue-theme {
      background-color: #e6f4f9;
      color: #003344;
    }
    body.iceblue-theme header,
    body.iceblue-theme .top-bar,
    body.iceblue-theme nav {
      background-color: #5dc7e8;
      color: #fff;
    }
    body.iceblue-theme .btn-auth {
      background-color: #d1ecf5;
      color: #00566b;
    }
    body.iceblue-theme nav a:hover {
      color: #004d66;
    }
    body.iceblue-theme .actualites-title {
      color: #009acd;
    }

    /* === THÈME VIOLET POUR AIDE-SOIGNANT === */
    body.violet-theme {
      background-color: #f5f0ff;
      color: #3c2c4e;
    }
    body.violet-theme header,
    body.violet-theme .top-bar,
    body.violet-theme nav {
      background-color: #7a57c2;
      color: white;
    }
    body.violet-theme .btn-auth {
      background-color: #e2d6f7;
      color: #472f75;
    }
    body.violet-theme nav a:hover {
      color: #e8dfff;
    }
    body.violet-theme .actualites-title {
      color: #8855cc;
    }

    /* === THÈME VERT MILITAIRE POUR MALADE === */
    body.military-theme {
      background-color: #f4f9f4;
      color: #223322;
    }
    body.military-theme header,
    body.military-theme .top-bar,
    body.military-theme nav {
      background-color: #4b6043;
      color: white;
    }
    body.military-theme .btn-auth {
      background-color: #cce3cc;
      color: #2e4d2e;
    }
    body.military-theme nav a:hover {
      color: #aaffaa;
    }
    body.military-theme .actualites-title {
      color: #668d55;
    }

    /* === THÈME ROSE POUR MANIPULATEUR === */
    body.pink-theme {
      background-color: #fff0f5;
      color: #5a2a4d;
    }
    body.pink-theme header,
    body.pink-theme .top-bar,
    body.pink-theme nav {
      background-color: #e673b2;
      color: white;
    }
    body.pink-theme .btn-auth {
      background-color: #fdd2ea;
      color: #b44a87;
    }
    body.pink-theme nav a:hover {
      color: #fff4f9;
    }
    body.pink-theme .actualites-title {
      color: #db3e91;
    }


      /* === THÈME SOMBRE POUR ADMIN/ADMINPRINCIPAL === */
      :root {
        --bg-color: #1e1e2f;
        --card-color: #2a2a3d;
        --text-color: #ffffff;
        --border-color: #444;
        --primary: #4dabf7;
        --accent: #ffcb6b;
      }

      body.dark-theme {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: 'Segoe UI', sans-serif;
      }

      /* Entêtes, barres du haut, navigation */
      body.dark-theme header,
      body.dark-theme .top-bar,
      body.dark-theme nav {
        background-color: var(--card-color);
        color: var(--text-color);
        border-bottom: 1px solid var(--border-color);
      }

      /* Pied de page */
      body.dark-theme footer {
        background-color: var(--card-color);
        color: #cccccc;
        border-top: 1px solid var(--border-color);
      }

      /* Boutons d’authentification */
      body.dark-theme .auth-buttons .btn-auth {
        background-color: #333;
        color: var(--text-color);
        border: 1px solid var(--border-color);
      }

      body.dark-theme .btn-auth:hover {
        background-color: #444;
        color: #fff;
      }

      /* Navigation */
      body.dark-theme nav a {
        color: #cccccc;
      }

      body.dark-theme nav a:hover {
        color: #ffffff;
      }

      /* Carrousel */
      body.dark-theme .carousel-container {
        background-color: var(--card-color);
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.05);
      }

      /* Overlay */
      body.dark-theme .overlay {
        background-color: rgba(30, 30, 48, 0.85);
      }

      /* Conteneur d’actualités */
      body.dark-theme .actualites-container {
        border: 2px solid var(--border-color);
        background-color: var(--card-color);
      }

      /* Titre des actualités */
      body.dark-theme .actualites-title {
        color: var(--accent);
      }

      /* Images dans l’en-tête */
      body.dark-theme .header-content img {
        background-color: #2b2b3d;
        padding: 8px;
        border-radius: 8px;
      }
    }
  </style>
</head>
  <body class="<% if (utilisateur) {
    if (['admin', 'adminprincipal'].includes(utilisateur.role)) { %>dark-theme<% 
    } else if (utilisateur.role === 'kinesitherapeute') { %>orange-theme<% 
    } else if (utilisateur.role === 'infirmier') { %>iceblue-theme<% 
    } else if (utilisateur.role === 'aidesoignant') { %>violet-theme<% 
    } else if (utilisateur.role === 'malade') { %>military-theme<% 
    } else if (utilisateur.role === 'manipulateur') { %>pink-theme<% 
    } 
  } %>">


  <!-- === BARRE DU HAUT === -->
  <div class="top-bar">
    <div id="welcomeMessage" style="color: white; font-size: 18px; font-weight: bold;">
      <% if (utilisateur && utilisateur.nom) { %>
        Bienvenue <%= utilisateur.nom %>
      <% } %>
    </div>
    <div class="auth-buttons">
      <% if (utilisateur && (utilisateur.role === 'admin' || utilisateur.role === 'adminprincipal')) { %>
        <button class="btn-auth" onclick="window.location.href='/admin'">Admin</button>
      <% } %>
      <% if (!utilisateur) { %>
        <button class="btn-auth" onclick="window.location.href='/login'">Connexion</button>
        <button class="btn-auth" onclick="window.location.href='/register'">Inscription</button>
      <% } else { %>
        <form action="/logout" method="POST" style="display: inline;">
          <button type="submit" class="btn-auth">Déconnexion</button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- === EN-TÊTE === -->
              <header>
                <div class="header-content">
                    <% 
                      const role = utilisateur?.role;
                      let logogauche = 'logogauche.png';
                      let logodroit = 'logodroit.png';

                      if (role) {
                        switch (role) {
                          case 'kinesitherapeute':
                            logogauche = 'logogauche1.png';
                            logodroit = 'logodroit1.png';
                            break;
                          case 'admin':
                          case 'adminprincipal':
                            logogauche = 'logogauche2.png';
                            logodroit = 'logodroit2.png';
                            break;
                          case 'infirmier':
                            logogauche = 'logogauche3.png';
                            logodroit = 'logodroit3.png';
                            break;
                          case 'aidesoignant':
                            logogauche = 'logogauche4.png';
                            logodroit = 'logodroit4.png';
                            break;
                          case 'malade':
                            logogauche = 'logogauche5.png';
                            logodroit = 'logodroit5.png';
                            break;
                          case 'manipulateur':
                            logogauche = 'logogauche6.png';
                            logodroit = 'logodroit6.png';
                            break;
                        }
                      }
                    %>

                  <img src="/images/<%= logogauche %>" alt="logo gauche personnalisé">

                  <div class="titre-et-tagline">
                    <h1>Service de Réanimation Médicale Polyvalente - CHU Mustapha</h1>
                    <p class="tagline">« Allier science et compassion en situation critique. »</p>
                  </div>

                  <% if (utilisateur) { %>
                    <img src="/images/<%= logodroit %>" alt="logo droit personnalisé">
                  <% } else { %>
                    <img src="/images/logodroit.png" alt="logo droit par défaut">
                  <% } %>
                </div>
                    <nav>
                        <a href="/">Accueil</a>
                        <a href="/presentation">Présentation</a>
                        <a href="/equipe">Équipe</a>
                        <a href="/contact">Contact</a>
                        <a href="/formations">Formations</a>
                        <a href="/protocoles">Nos protocoles</a>
                        <a href="/experiences">Nos expériences</a>
                        <% if (user && user.role === 'malade') { %>
                          <a href="/malades">Espace Malades</a>
                        <% } %>
                        <% if (user && user.role === 'personnel') { %>
                          <a href="/personnel">Espace Personnel</a>
                        <% } %>
                      </nav>
                    </header>
              </header>

  <!-- === CONTENU PRINCIPAL === -->
  <main>
    <section class="carousel-container">
      <div class="carousel-slides" id="carouselSlides">
        <img src="/panorama1.jpg" alt="Panorama 1">
        <img src="/panorama2.jpg" alt="Panorama 2">
        <img src="/panorama3.jpg" alt="Panorama 3">
      </div>
      <% if (!utilisateur) { %>
        <div class="overlay">
          <h2>Bienvenue sur notre site.</h2>
          <p>Connectez-vous pour accéder à votre espace personnel.</p>
        </div>
      <% } %>
    </section>

    <section class="actualites-container">
      <a href="/actualites" style="text-decoration: none;">
        <h2 class="actualites-title">Actualités</h2>
      </a>
      <p>Consultez les dernières nouvelles et mises à jour.</p>
    </section>
  </main>

  <footer>
    <p>&copy; 2025 Service de Réanimation - CHU Mustapha. Tous droits réservés.</p>
  </footer>

  <div class="poster-wrapper">
    <a href="https://sarm.dz/" target="_blank">
      <img src="/ton-image.jpg" alt="Affiche SARM non trouvée">
    </a>
  </div>

  <script>
    const slides = document.getElementById('carouselSlides');
    let index = 0;
    setInterval(() => {
      index = (index + 1) % 3;
      slides.style.transform = `translateX(-${index * 100}%)`;
    }, 4000);
  </script>
</body>
</html>