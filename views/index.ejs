    <!DOCTYPE html>
    <html lang="fr">
    <head>
      <meta charset="UTF-8">
      <title>Service de Réanimation - CHU Mustapha</title>
      <style>
        /* === BASE === */
        body {
          margin: 0;
          font-family: Arial, sans-serif;
        }

        header, footer {
          color: white;
        }

        .top-bar {
          display: flex;
          justify-content: space-between;
          align-items: center;
          padding: 10px 20px;
        }

        .auth-buttons {
          display: flex;
          gap: 10px;
        }

        .btn-auth {
          border: none;
          border-radius: 4px;
          padding: 8px 14px;
          font-weight: bold;
          font-size: 14px;
          cursor: pointer;
          transition: transform 0.2s ease, background-color 0.3s ease;
        }

        .btn-auth:hover {
          transform: scale(1.05);
        }

        .header-content {
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 10px 40px;
        }

        .header-content img {
          max-height: 150px;
          height: auto;
          width: auto;
        }

        .titre-et-tagline {
          text-align: center;
          flex: 1;
        }

        .titre-et-tagline h1 {
          font-size: 26px;
          margin: 10px 0 5px;
        }

        nav {
          text-align: center;
          padding: 10px 0;
        }

        nav a {
          margin: 0 12px;
          text-decoration: none;
          font-weight: bold;
          transition: color 0.3s ease;
        }

        main {
          padding: 20px;
          text-align: center;
        }

        footer {
          text-align: center;
          padding: 15px 0;
          margin-top: 30px;
          font-size: 14px;
        }

        .carousel-container {
          width: 90%;
          max-width: 1000px;
          height: 450px;
          margin: 30px auto;
          overflow: hidden;
          position: relative;
          border-radius: 12px;
          box-shadow: 0 0 10px rgba(0,0,0,0.2);
        }

        .carousel-slides {
          display: flex;
          transition: transform 1s ease;
          height: 100%;
        }

        .carousel-slides img {
          width: 100%;
          height: 100%;
          object-fit: contain;
          flex-shrink: 0;
        }

        .overlay {
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          color: white;
          padding: 20px 30px;
          border-radius: 10px;
          text-align: center;
        }

        .actualites-container {
          margin-top: 40px;
          padding: 20px;
          border-radius: 10px;
          animation: fadeIn 2s ease-in-out;
        }

        .actualites-title {
          font-size: 32px;
          font-weight: bold;
          margin-bottom: 10px;
          animation: bounce 2s infinite;
        }

        @keyframes bounce {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-10px); }
        }

        @keyframes fadeIn {
          0% { opacity: 0; transform: translateY(20px); }
          100% { opacity: 1; transform: translateY(0); }
        }

        .poster-wrapper {
          position: fixed;
          top: 30%;
          right: -400px;
          z-index: 10000;
          transition: right 0.4s ease, opacity 0.4s ease;
          opacity: 0.6;
          border-radius: 8px 0 0 8px;
        }

        .poster-wrapper img {
          height: 300px;
          cursor: pointer;
        }

        .poster-wrapper:hover {
          right: 0;
          opacity: 1;
        }

        /* === THÈMES AMÉLIORÉS AVEC NUANCES === */

        body.orange-theme {
          background: linear-gradient(to bottom, #fff2ed, #ffe9e2);
          color: #4d2e1a;
        }

        body.orange-theme header,
        body.orange-theme .top-bar,
        body.orange-theme nav {
          background: linear-gradient(to right, #ff6f50, #ff8465);
        }

        body.orange-theme .btn-auth {
          background: #ffdad0;
          color: #b8432b;
        }

        body.orange-theme .btn-auth:hover {
          background: #ffc4b5;
        }

        body.orange-theme .actualites-container {
          border: 2px solid #ff7f50;
          background-color: #fff5f1;
        }

        body.orange-theme .actualites-title {
          color: #ff5a36;
        }

        body.iceblue-theme {
          background: linear-gradient(to bottom, #e6f4f9, #cfeefb);
          color: #003344;
        }

        body.iceblue-theme header,
        body.iceblue-theme .top-bar,
        body.iceblue-theme nav {
          background: linear-gradient(to right, #5dc7e8, #91dff4);
        }

        body.iceblue-theme .btn-auth {
          background: #d1ecf5;
          color: #004e60;
        }

        body.iceblue-theme .btn-auth:hover {
          background: #bce5f0;
        }

        body.iceblue-theme .actualites-container {
          border: 2px solid #5dc7e8;
          background-color: #e6faff;
        }

        body.iceblue-theme .actualites-title {
          color: #00a3cc;
        }

        body.violet-theme {
          background: linear-gradient(to bottom, #f5f0ff, #ebe0ff);
          color: #3c2c4e;
        }

        body.violet-theme header,
        body.violet-theme .top-bar,
        body.violet-theme nav {
          background: linear-gradient(to right, #7a57c2, #9d7ed9);
        }

        body.violet-theme .btn-auth {
          background: #e2d6f7;
          color: #472f75;
        }

        body.violet-theme .btn-auth:hover {
          background: #d3c2f0;
        }

        body.violet-theme .actualites-title {
          color: #8855cc;
        }

        body.military-theme {
          background: linear-gradient(to bottom, #f4f9f4, #e5f0e5);
          color: #223322;
        }

        body.military-theme header,
        body.military-theme .top-bar,
        body.military-theme nav {
          background: linear-gradient(to right, #4b6043, #6e8c5c);
        }

        body.military-theme .btn-auth {
          background: #d6ecd6;
          color: #2e4d2e;
        }

        body.military-theme .btn-auth:hover {
          background: #c2e2c2;
        }

        body.military-theme .actualites-title {
          color: #5c7d48;
        }

        body.pink-theme {
          background: linear-gradient(to bottom, #fff0f5, #ffe0ed);
          color: #5a2a4d;
        }

        body.pink-theme header,
        body.pink-theme .top-bar,
        body.pink-theme nav {
          background: linear-gradient(to right, #e673b2, #f597cd);
        }

        body.pink-theme .btn-auth {
          background: #fdd2ea;
          color: #b44a87;
        }

        body.pink-theme .btn-auth:hover {
          background: #fbbce0;
        }

        body.pink-theme .actualites-title {
          color: #db3e91;
        }

        body.dark-theme {
          background-color: #1e1e2f;
          color: #ffffff;
          font-family: 'Segoe UI', sans-serif;
        }

        body.dark-theme header,
        body.dark-theme .top-bar,
        body.dark-theme nav {
          background: linear-gradient(to right, #2a2a3d, #383857);
          border-bottom: 1px solid #444;
        }

        body.dark-theme footer {
          background-color: #2a2a3d;
          color: #cccccc;
          border-top: 1px solid #444;
        }

        body.dark-theme .auth-buttons .btn-auth {
          background-color: #333;
          color: #ffffff;
          border: 1px solid #444;
        }

        body.dark-theme .btn-auth:hover {
          background-color: #444;
        }

        body.dark-theme nav a {
          color: #cccccc;
        }

        body.dark-theme nav a:hover {
          color: #ffffff;
        }

        body.dark-theme .carousel-container {
          background-color: #2a2a3d;
        }

        body.dark-theme .overlay {
          background-color: rgba(30, 30, 48, 0.85);
        }

        body.dark-theme .actualites-container {
          border: 2px solid #444;
          background-color: #2a2a3d;
        }

        body.dark-theme .actualites-title {
          color: #ffcb6b;
        }

        body.dark-theme .header-content img {
          background-color: #2b2b3d;
          padding: 8px;
          border-radius: 8px;
        }
      </style>
    </head>
    <body class="<% if (utilisateur) {
        if (['admin', 'adminprincipal'].includes(utilisateur.role)) { %>dark-theme<%
        } else if (utilisateur.role === 'kinesitherapeute') { %>orange-theme<%
        } else if (utilisateur.role === 'infirmier') { %>iceblue-theme<%
        } else if (utilisateur.role === 'aidesoignant') { %>violet-theme<%
        } else if (utilisateur.role === 'malade') { %>military-theme<%
        } else if (utilisateur.role === 'manipulateur') { %>pink-theme<%
        }
      } %>">


  <!-- === BARRE DU HAUT === -->
  <div class="top-bar">
    <div id="welcomeMessage" style="color: white; font-size: 18px; font-weight: bold;">
      <% if (utilisateur && utilisateur.nom) { %>
        Bienvenue <%= utilisateur.nom %>
      <% } %>
    </div>
    <div class="auth-buttons">
      <% if (utilisateur && (utilisateur.role === 'admin' || utilisateur.role === 'adminprincipal')) { %>
        <button class="btn-auth" onclick="window.location.href='/admin'">Admin</button>
      <% } %>
      <% if (!utilisateur) { %>
        <button class="btn-auth" onclick="window.location.href='/login'">Connexion</button>
        <button class="btn-auth" onclick="window.location.href='/register'">Inscription</button>
      <% } else { %>
        <form action="/logout" method="POST" style="display: inline;">
          <button type="submit" class="btn-auth">Déconnexion</button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- === EN-TÊTE === -->
              <header>
                <div class="header-content">
                    <% 
                      const role = utilisateur?.role;
                      let logogauche = 'logogauche.png';
                      let logodroit = 'logodroit.png';

                      if (role) {
                        switch (role) {
                          case 'kinesitherapeute':
                            logogauche = 'logogauche1.png';
                            logodroit = 'logodroit1.png';
                            break;
                          case 'admin':
                          case 'adminprincipal':
                            logogauche = 'logogauche2.png';
                            logodroit = 'logodroit2.png';
                            break;
                          case 'infirmier':
                            logogauche = 'logogauche3.png';
                            logodroit = 'logodroit3.png';
                            break;
                          case 'aidesoignant':
                            logogauche = 'logogauche4.png';
                            logodroit = 'logodroit4.png';
                            break;
                          case 'malade':
                            logogauche = 'logogauche5.png';
                            logodroit = 'logodroit5.png';
                            break;
                          case 'manipulateur':
                            logogauche = 'logogauche6.png';
                            logodroit = 'logodroit6.png';
                            break;
                        }
                      }
                    %>

                  <img src="/images/<%= logogauche %>" alt="logo gauche personnalisé">

                  <div class="titre-et-tagline">
                    <h1>Service de Réanimation Médicale Polyvalente - CHU Mustapha</h1>
                    <p class="tagline">« Allier science et compassion en situation critique. »</p>
                  </div>

                  <% if (utilisateur) { %>
                    <img src="/images/<%= logodroit %>" alt="logo droit personnalisé">
                  <% } else { %>
                    <img src="/images/logodroit.png" alt="logo droit par défaut">
                  <% } %>
                </div>
                    <nav>
                        <a href="/">Accueil</a>
                        <a href="/presentation">Présentation</a>
                        <a href="/equipe">Équipe</a>
                        <a href="/contact">Contact</a>
                        <a href="/formations">Formations</a>
                        <a href="/protocoles">Nos protocoles</a>
                        <a href="/experiences">Nos expériences</a>
                        <% if (utilisateur && utilisateur.role === 'malade') { %>
                          <a href="/malades">Espace Malades</a>
                        <% } %>
                        <% if (utilisateur && utilisateur.role === 'personnel') { %>
                          <a href="/personnel">Espace Personnel</a>
                        <% } %>
                      </nav>
                    </header>
              </header>

  <!-- === CONTENU PRINCIPAL === -->
  <main>
    <section class="carousel-container">
      <div class="carousel-slides" id="carouselSlides">
        <img src="/panorama1.jpg" alt="Panorama 1">
        <img src="/panorama2.jpg" alt="Panorama 2">
        <img src="/panorama3.jpg" alt="Panorama 3">
      </div>
      <% if (!utilisateur) { %>
        <div class="overlay">
          <h2>Bienvenue sur notre site.</h2>
          <p>Connectez-vous pour accéder à votre espace personnel.</p>
        </div>
      <% } %>
    </section>

    <section class="actualites-container">
      <a href="/actualites" style="text-decoration: none;">
        <h2 class="actualites-title">Actualités</h2>
      </a>
      <p>Consultez les dernières nouvelles et mises à jour.</p>
    </section>
  </main>

  <footer>
    <p>&copy; 2025 Service de Réanimation - CHU Mustapha. Tous droits réservés.</p>
  </footer>

  <div class="poster-wrapper">
    <a href="https://sarm.dz/" target="_blank">
      <img src="/ton-image.jpg" alt="Affiche SARM non trouvée">
    </a>
  </div>

  <script>
    const slides = document.getElementById('carouselSlides');
    let index = 0;
    setInterval(() => {
      index = (index + 1) % 3;
      slides.style.transform = `translateX(-${index * 100}%)`;
    }, 4000);
  </script>
</body>
</html>